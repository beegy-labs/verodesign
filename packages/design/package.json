{
  "name": "@verobee/design",
  "version": "0.0.1",
  "description": "Verobee Design System — token-driven CSS architecture, OKLCH-first, Tailwind-independent.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.min.css",
    "dist/theme-init.js",
    "dist/cli/vds.js",
    "dist/types/**/*.d.ts",
    "tokens/**/*.json",
    "!tokens/experimental/**",
    "!tokens/themes/_template-*.json",
    "scripts/build.mjs",
    "scripts/validate.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    "./css/tokens.property.css": "./dist/css/tokens.property.min.css",
    "./css/core.css": "./dist/css/core.min.css",
    "./css/reset.css": "./dist/css/reset.min.css",
    "./css/prose.css": "./dist/css/prose.min.css",
    "./css/themes/*.css": "./dist/css/themes/*.min.css",
    "./prose": "./dist/css/prose.min.css",
    "./utilities/full": "./dist/utilities/full.min.css",
    "./utilities/state-variants": "./dist/utilities/state-variants.min.css",
    "./utilities/group-variants": "./dist/utilities/group-variants.min.css",
    "./utilities/responsive": "./dist/utilities/responsive.min.css",
    "./utilities/by-category/*": "./dist/utilities/by-category/*.min.css",
    "./utilities/*.css": "./dist/utilities/*.min.css",
    "./animations": "./dist/animations.min.css",
    "./animations.css": "./dist/animations.min.css",
    "./types/*": "./dist/types/*",
    "./theme-init.js": "./dist/theme-init.js",
    "./tokens/*": "./tokens/*",
    "./full": "./dist/verodesign.full.min.css",
    "./full.css": "./dist/verodesign.full.min.css",
    "./package.json": "./package.json"
  },
  "bin": {
    "vds": "./dist/cli/vds.js",
    "verodesign": "./dist/cli/vds.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "rm -rf dist && mkdir -p dist",
    "rebuild": "pnpm clean && pnpm build",
    "validate": "node scripts/validate.mjs",
    "prepublishOnly": "pnpm rebuild && pnpm validate"
  },
  "devDependencies": {
    "culori": "^4.0.1",
    "lightningcss": "^1.32.0",
    "style-dictionary": "^4.4.0",
    "wcag-contrast": "^3.0.0"
  }
}
