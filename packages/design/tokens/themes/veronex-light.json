{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "verobee": {
      "tier": "theme",
      "theme": "veronex",
      "mode": "light",
      "implements": ["core", "web"],
      "since": "v0.1.0",
      "concept": "Verde Nexus — deep ivy authority",
      "primary": "OKLCH(30% 0.06 150) Deep Ivy",
      "accent": "OKLCH(50% 0.152 180) Teal — analogous-harmonious"
    }
  },
  "theme": {
    "primary": { "$value": "oklch(30% 0.06 150)", "$type": "color" },
    "primary-fg": { "$value": "{color.white}", "$type": "color" },
    "primary-ring": { "$value": "oklch(40% 0.10 150)", "$type": "color" },
    "accent": { "$value": "{color.teal.7}", "$type": "color" },
    "accent-fg": { "$value": "{color.white}", "$type": "color" },
    "border": {
      "focus": { "$value": "oklch(40% 0.10 150)", "$type": "color" }
    },
    "info": { "$value": "oklch(30% 0.06 150)", "$type": "color" },
    "info-fg": { "$value": "{color.white}", "$type": "color" },
    "chart": {
      "1": { "$value": "oklch(30% 0.06 150)", "$type": "color" },
      "2": { "$value": "{color.teal.6}", "$type": "color" },
      "3": { "$value": "{color.lime.6}", "$type": "color" },
      "4": { "$value": "{color.amber.6}", "$type": "color" },
      "5": { "$value": "{color.indigo.6}", "$type": "color" }
    }
  }
}
