{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "verobee": {
      "tier": "theme",
      "theme": "verobase",
      "mode": "light",
      "implements": ["core", "web"],
      "since": "v0.1.0",
      "concept": "Verobase Solution Light — verde sage + honey accent",
      "primary": "OKLCH(45% 0.13 155) Sage Verde",
      "accent": "OKLCH(72% 0.14 80) Soft Honey"
    }
  },
  "theme": {
    "bg": {
      "page": { "$value": "oklch(99% 0.003 90)", "$type": "color" },
      "card": { "$value": "oklch(98% 0.004 90)", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "oklch(25% 0.020 155)", "$type": "color", "$description": "Override: soft near-black, verde undertone" },
      "dim": { "$value": "oklch(50% 0.015 155)", "$type": "color", "$description": "Override: verde-toned dim text" },
      "faint": {
        "$value": "oklch(65% 0.012 155)",
        "$type": "color",
        "$extensions": { "verobee": { "contrast": { "allow": "AA-large", "rationale": "Hint text only" } } }
      }
    },
    "primary": { "$value": "oklch(45% 0.13 155)", "$type": "color" },
    "primary-fg": { "$value": "oklch(99% 0.003 90)", "$type": "color" },
    "primary-ring": { "$value": "oklch(60% 0.14 155)", "$type": "color" },
    "accent": { "$value": "oklch(72% 0.14 80)", "$type": "color" },
    "accent-fg": { "$value": "oklch(25% 0.04 80)", "$type": "color" },
    "border": {
      "focus": { "$value": "oklch(60% 0.14 155)", "$type": "color" }
    },
    "info": { "$value": "oklch(45% 0.13 155)", "$type": "color" },
    "info-fg": { "$value": "oklch(99% 0.003 90)", "$type": "color" },
    "chart": {
      "1": { "$value": "oklch(45% 0.13 155)", "$type": "color" },
      "2": { "$value": "oklch(72% 0.14 80)", "$type": "color" },
      "3": { "$value": "oklch(60% 0.10 215)", "$type": "color" },
      "4": { "$value": "oklch(60% 0.16 305)", "$type": "color" },
      "5": { "$value": "oklch(55% 0.12 25)", "$type": "color" }
    },
    "logo": {
      "start": { "$value": "oklch(45% 0.13 155)", "$type": "color" },
      "end": { "$value": "oklch(72% 0.14 80)", "$type": "color" },
      "inner": { "$value": "oklch(99% 0.003 90)", "$type": "color" }
    }
  }
}
