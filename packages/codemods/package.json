{
  "name": "@verobee/codemods",
  "version": "1.0.0",
  "description": "Verobee Design System — jscodeshift transforms for migrating between verodesign versions.",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "verobee-codemod": "./dist/cli.js"
  },
