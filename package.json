{
  "name": "verodesign",
  "version": "0.0.1",
  "description": "Verobee Design System monorepo — tokens, web components, framework adapters.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "validate": "turbo run validate",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "build:design": "pnpm --filter @verobee/design build",
    "validate:design": "pnpm --filter @verobee/design validate"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
