{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "verobee": {
      "tier": "theme",
      "theme": "verobase",
      "mode": "light",
      "implements": ["core", "web"],
      "since": "v0.1.0",
      "concept": "Vero Base — deep navy enterprise",
      "primary": "OKLCH(32% 0.07 250) Deep Navy",
      "accent": "OKLCH(50% 0.171 50) Orange — split-complementary"
    }
  },
  "theme": {
    "primary": { "$value": "oklch(32% 0.07 250)", "$type": "color" },
    "primary-fg": { "$value": "{color.white}", "$type": "color" },
    "primary-ring": { "$value": "oklch(45% 0.10 250)", "$type": "color" },
    "accent": { "$value": "{color.orange.7}", "$type": "color" },
    "accent-fg": { "$value": "{color.white}", "$type": "color" },
    "border": {
      "focus": { "$value": "oklch(45% 0.10 250)", "$type": "color" }
    },
    "info": { "$value": "oklch(32% 0.07 250)", "$type": "color" },
    "info-fg": { "$value": "{color.white}", "$type": "color" },
    "chart": {
      "1": { "$value": "oklch(32% 0.07 250)", "$type": "color" },
      "2": { "$value": "{color.cyan.6}", "$type": "color" },
      "3": { "$value": "{color.orange.6}", "$type": "color" },
      "4": { "$value": "{color.violet.6}", "$type": "color" },
      "5": { "$value": "{color.green.6}", "$type": "color" }
    },
    "logo": {
      "start": { "$value": "oklch(32% 0.07 250)", "$type": "color" },
      "end": { "$value": "{color.blue.5}", "$type": "color" },
      "inner": { "$value": "{color.white}", "$type": "color" }
    }
  }
}
