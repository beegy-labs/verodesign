---
import DocLayout from "../../layouts/DocLayout.astro";

// Read the component manifest auto-generated by @verobee/design-elements.
// CEM (Custom Elements Manifest) is the canonical machine-readable contract.
import manifest from "@verobee/design-elements/dist/custom-elements.json";

const components = (manifest.modules ?? [])
  .flatMap((m: any) => m.declarations ?? [])
  .filter((d: any) => d.tagName)
  .sort((a: any, b: any) => a.tagName.localeCompare(b.tagName));
---
<DocLayout title="Components">
  <h1>Components</h1>
  <p>{components.length} Lit web components — usable in any framework.</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin-top: 2rem;">
    {components.map((c: any) => (
      <a
        href={`/components/${c.tagName.replace('vds-', '')}`}
        style="display: block; padding: 1rem; border: 1px solid var(--vds-theme-border-default); border-radius: 0.5rem; text-decoration: none; color: inherit; background: var(--vds-theme-bg-card);"
      >
        <code style="color: var(--vds-theme-primary);">&lt;{c.tagName}&gt;</code>
        <div style="font-size: 0.875rem; color: var(--vds-theme-text-dim); margin-top: 0.5rem;">
          {c.summary || c.description?.split('\n')[0] || c.name}
        </div>
      </a>
    ))}
  </div>
</DocLayout>
