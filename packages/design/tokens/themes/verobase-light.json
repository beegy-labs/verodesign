{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "verobee": {
      "tier": "theme",
      "theme": "verobase",
      "mode": "light",
      "implements": ["core", "web"],
      "since": "v0.1.0",
      "concept": "Verobase Solution Light — verde sage + honey accent (gardener mode)",
      "primary": "OKLCH(45% 0.13 155) Sage Verde",
      "accent": "OKLCH(72% 0.14 80) Soft Honey"
    }
  },
  "theme": {
    "bg": {
      "page":     { "$value": "oklch(99% 0.003 90)",  "$type": "color" },
      "card":     { "$value": "oklch(98% 0.004 90)",  "$type": "color" },
      "selected": { "$value": "oklch(96% 0.005 155)", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "oklch(25% 0.020 155)", "$type": "color" },
      "secondary": { "$value": "oklch(35% 0.018 155)", "$type": "color" },
      "dim":       { "$value": "oklch(50% 0.015 155)", "$type": "color" },
      "faint":     { "$value": "oklch(65% 0.012 155)", "$type": "color" }
    },
    "primary":      { "$value": "oklch(45% 0.13 155)",  "$type": "color" },
    "primary-fg":   { "$value": "oklch(99% 0.003 90)",  "$type": "color" },
    "primary-ring": { "$value": "oklch(60% 0.14 155)",  "$type": "color" },
    "accent":       { "$value": "oklch(72% 0.14 80)",   "$type": "color" },
    "accent-fg":    { "$value": "oklch(25% 0.04 80)",   "$type": "color" },
    "border": {
