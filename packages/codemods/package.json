    "transforms/**/*.{js,ts,mjs}",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test transforms/**/*.test.mjs"
  },
  "dependencies": {
    "jscodeshift": "^17.0.0"
  }
}
