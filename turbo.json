{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tokens/**",
        "transforms/**",
        "templates/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.build.json"
      ]
    },
    "validate": {
      "inputs": [
        "src/**",
        "scripts/**",
        "tokens/**",
        "package.json"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "transforms/**",
        "package.json"
      ]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "inputs": ["src/**", "scripts/**", "package.json"]
    }
  }
}
