{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tokens/**",
        "package.json",
        "tsconfig.json"
      ]
    },
    "validate": {
      "inputs": [
        "src/**",
        "scripts/**",
        "tokens/**"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "package.json"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
