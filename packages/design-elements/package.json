{
  "name": "@verobee/design-elements",
  "version": "0.0.1",
  "description": "Verobee Design System — Lit 3 web components, framework-agnostic, WAI-ARIA AP 1.2 compliant.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/components/**/define.js",
    "./dist/index.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./define/*": {
      "import": "./dist/components/*/define.js"
    },
    "./manifest": "./dist/custom-elements.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && cem analyze --litelement --globs 'src/**/*.ts' --outdir dist",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "test:ssr": "node test/ssr-smoke.mjs",
    "validate": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@verobee/design": "workspace:*"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@lit-labs/ssr": "^3.3.0",
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-playwright": "^0.11.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "customElements": "dist/custom-elements.json"
}
